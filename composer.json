{
    "name": "nikhil/laravel-sitemap",
    "description": "Laravel Sitemap package for Laravel.",
    "keywords": [
        "laravel",
        "php",
        "sitemap",
        "generator",
        "xml",
        "html",
        "google-news"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Nikhil Chudasama",
            "email": "chudasamanikhild@gmail.com",
            "role": "Developer",
            "homepage": "https://eyuva.com"
        }
    ],
    "support": {
        "issues": "https://github.com/Nikhilchudasama/sitemap/issues",
        "source": "https://github.com/Nikhilchudasama/sitemap"
    },
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.3",
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.14",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.1",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "Nikhil\\Sitemap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nikhil\\Sitemap\\Test\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nikhil\\Sitemap\\SitemapServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test",
        "refactor": "vendor/bin/rector --dry-run",
        "refactor:fix": "vendor/bin/rector",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    }
}

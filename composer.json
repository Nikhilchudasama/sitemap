{
    "name": "nik/laravel-sitemap",
    "description": "Laravel Sitemap package for Laravel.",
    "keywords": ["laravel", "php", "sitemap", "generator", "xml", "html", "google-news"],
    "license": "MIT",
    "version": "9.0.0",
    "authors": [
        {
            "name": "Nikhil Chudasama",
            "email": "chudasamanikhild@gmail.com",
            "role": "Developer",
            "homepage": "https://eyuva.com"
        }
    ],
    "support": {
        "issues": "https://github.com/Laravelium/laravel-sitemap/issues",
        "source": "https://github.com/Laravelium/laravel-sitemap",
        "wiki": "https://github.com/Laravelium/laravel-sitemap/wiki"
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Nik\\Sitemap\\": "src/Nik/Sitemap/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nik\\Sitemap\\SitemapServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
